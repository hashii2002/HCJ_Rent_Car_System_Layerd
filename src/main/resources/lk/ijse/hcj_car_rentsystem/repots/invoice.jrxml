<jasperReport name="invoice" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="90792309-bf69-4fd0-bb81-452c8da7b389">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="MYSQL-RENTCAR"/>
	<parameter name="PAYMENT_ID" class="java.lang.Integer"/>
	<query language="SQL"><![CDATA[SELECT 
    p.*, 
    v.brand AS vehicle_brand, 
    v.model AS vehicle_model
FROM payments p
JOIN bookings b ON p.booking_id = b.booking_id
JOIN vehicle_assign_details vad ON b.booking_id = vad.booking_id
JOIN vehicles v ON vad.vehicle_id = v.vehicle_id
WHERE p.payment_id = $P{PAYMENT_ID}]]></query>
